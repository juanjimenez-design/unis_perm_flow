title    = "Frecuencia de Acciones — Día × Hora",
subtitle = "¿Cuándo opera el equipo? (patrón de lanzamiento)",
x = "Hora del día", y = NULL, fill = "# Acciones"
) +
theme_scala() +
theme(legend.position = "right", panel.grid = element_blank())
# ── Heatmap 2: Tasa de apertura promedio (patrón de receptividad) ─────────────
p_heat_or <- agg_dia_hora %>%
ggplot(aes(x = hora_num, y = forcats::fct_rev(dia_semana),
fill = tasa_apertura)) +
geom_tile(color = "white", linewidth = 0.4) +
scale_fill_gradient(low = "#F7F7FB", high = pal$naranja,
labels = scales::percent_format(accuracy = 0.1),
na.value = pal$gris) +
scale_x_continuous(breaks = seq(0, 23, 2),
labels = paste0(seq(0, 23, 2), "h"),
expand = c(0, 0)) +
scale_y_discrete(expand = c(0, 0)) +
labs(
title    = "Tasa de Apertura (OR) — Día × Hora",
subtitle = "¿Cuándo abre la audiencia? (patrón de receptividad)",
x = "Hora del día", y = NULL, fill = "OR (%)"
) +
theme_scala() +
theme(legend.position = "right", panel.grid = element_blank())
# ── Heatmap 3: CTOR (calidad del contenido) ────────────────────────────────────
p_heat_ctor <- agg_dia_hora %>%
ggplot(aes(x = hora_num, y = forcats::fct_rev(dia_semana),
fill = ctor)) +
geom_tile(color = "white", linewidth = 0.4) +
scale_fill_gradient(low = "#F7F7FB", high = pal$turquesa,
labels = scales::percent_format(accuracy = 0.1),
na.value = pal$gris) +
scale_x_continuous(breaks = seq(0, 23, 2),
labels = paste0(seq(0, 23, 2), "h"),
expand = c(0, 0)) +
scale_y_discrete(expand = c(0, 0)) +
labs(
title    = "CTOR — Día × Hora",
subtitle = "Clics / Aperturas — calidad del contenido para quienes abrieron",
x = "Hora del día", y = NULL, fill = "CTOR (%)"
) +
theme_scala() +
theme(legend.position = "right", panel.grid = element_blank())
(p_heat_n / p_heat_or / p_heat_ctor) +
plot_annotation(
title   = "Mapas de Calor: Actividad y Receptividad por Día y Hora",
caption = "Scala Learning / S4L Colombia",
theme   = theme_scala()
)
df_ts %>%
filter(!is.na(canal)) %>%
pivot_longer(
cols      = c(tasa_apertura, ctor, tasa_clic),
names_to  = "tasa",
values_to = "valor"
) %>%
ggplot(aes(x = canal, y = valor, fill = canal)) +
geom_boxplot(alpha = 0.75, outlier.size = 1.2, outlier.alpha = 0.35,
outlier.color = pal$terracota) +
scale_fill_manual(
values = colorRampPalette(c(pal$violeta, pal$naranja, pal$turquesa,
pal$verde, pal$amarillo))(
n_distinct(df_ts$canal, na.rm = TRUE)
)
) +
scale_y_continuous(labels = scales::percent_format(accuracy = 0.1)) +
facet_wrap(~ tasa, scales = "free_y",
labeller = labeller(tasa = c(
tasa_apertura = "OR — Tasa de Apertura",
ctor          = "CTOR — Clic / Apertura",
tasa_clic     = "CTR — Tasa de Clic"
))
) +
labs(
title    = "Distribución de Tasas de Engagement por Canal",
subtitle = "Boxplot con outliers — variabilidad intra-canal y comparativa",
x = NULL, y = NULL,
caption  = "Scala Learning / S4L Colombia"
) +
theme_scala() +
theme(legend.position = "none",
axis.text.x = element_text(angle = 30, hjust = 1))
df_ts %>%
filter(!is.na(etapa)) %>%
group_by(mes, etapa) %>%
summarise(
tasa_apertura = mean(tasa_apertura, na.rm = TRUE),
ctor          = mean(ctor,          na.rm = TRUE),
.groups = "drop"
) %>%
pivot_longer(cols = c(tasa_apertura, ctor),
names_to  = "indicador",
values_to = "valor") %>%
ggplot(aes(x = mes, y = valor, color = indicador, group = indicador)) +
geom_line(linewidth = 0.9) +
geom_point(size = 1.8) +
scale_color_manual(
values = c(tasa_apertura = pal$verde, ctor = pal$naranja),
labels = c("CTOR", "OR")
) +
scale_y_continuous(labels = scales::percent_format(accuracy = 0.1)) +
scale_x_datetime(date_labels = "%b", date_breaks = "1 month") +
facet_wrap(~ etapa, scales = "free_y") +
labs(
title    = "Tendencia OR y CTOR por Etapa del Funnel",
subtitle = "¿Las etapas evolucionan de forma homogénea o hay divergencias?",
x = NULL, y = NULL, color = "Indicador",
caption  = "Scala Learning / S4L Colombia"
) +
theme_scala() +
theme(axis.text.x = element_text(angle = 45, hjust = 1, size = 7))
df_ts %>%
filter(!is.na(categoria)) %>%
group_by(categoria) %>%
summarise(
n             = n(),
OR            = mean(tasa_apertura, na.rm = TRUE),
CTOR          = mean(ctor,          na.rm = TRUE),
CTR           = mean(tasa_clic,     na.rm = TRUE),
.groups = "drop"
) %>%
# Ordenar por OR descendente para lectura ejecutiva
mutate(categoria = reorder(categoria, OR)) %>%
pivot_longer(cols = c(OR, CTOR, CTR),
names_to  = "indicador",
values_to = "valor") %>%
ggplot(aes(x = categoria, y = valor, fill = indicador)) +
geom_col(position = "dodge", alpha = 0.88) +
scale_fill_manual(
values = c(OR = pal$verde, CTOR = pal$turquesa, CTR = pal$naranja)
) +
scale_y_continuous(labels = scales::percent_format(accuracy = 0.1)) +
coord_flip() +
labs(
title    = "Tasas de Engagement por Categoría",
subtitle = "Promedio OR · CTOR · CTR — ordenado por OR",
x = NULL, y = "Tasa (%)", fill = "Indicador",
caption  = "Scala Learning / S4L Colombia"
) +
theme_scala()
df_ts %>%
filter(!is.na(cohorte)) %>%
group_by(mes, cohorte) %>%
summarise(
OR  = mean(tasa_apertura, na.rm = TRUE),
CTR = mean(tasa_clic,     na.rm = TRUE),
.groups = "drop"
) %>%
ggplot(aes(x = mes, y = OR, color = cohorte, group = cohorte)) +
geom_line(linewidth = 0.9, alpha = 0.85) +
geom_point(size = 1.8) +
scale_y_continuous(labels = scales::percent_format(accuracy = 0.1)) +
scale_x_datetime(date_labels = "%b %Y", date_breaks = "1 month") +
labs(
title    = "Evolución del OR por Cohorte",
subtitle = "¿Las cohortes nuevas mejoran el engagement respecto a las anteriores?",
x = NULL, y = "OR (%)", color = "Cohorte",
caption  = "Scala Learning / S4L Colombia"
) +
theme_scala() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
# ── Tabla de estadísticas descriptivas por canal ──────────────────────────────
# La función describir_serie() definida en setup acepta cualquier grupo_var.
# Aquí se aplica a 'canal'; reemplazar por 'etapa', 'campana', etc. según foco.
describir_serie(df_ts, grupo_var = "canal") %>%
filter(metrica %in% c("tasa_apertura", "ctor", "tasa_clic")) %>%
select(canal, metrica, N, Media, Mediana, DE, CV, Min, Max) %>%
arrange(canal, metrica) %>%
kable(caption = "Estadísticas descriptivas de tasas por Canal",
digits = 4) %>%
kable_styling(bootstrap_options = c("striped", "hover", "condensed"),
full_width = TRUE, font_size = 12) %>%
row_spec(0, background = "#585D8A", color = "white", bold = TRUE)
# ── Directorio de salida ──────────────────────────────────────────────────────
# eval=FALSE por defecto: ejecutar manualmente o cambiar a TRUE para runs batch.
dir.create("../output/plots_ts", showWarnings = FALSE, recursive = TRUE)
# ── Exportar datos agregados a Excel ──────────────────────────────────────────
# Para consumo en Power BI o reportes ejecutivos sin regenerar el Rmd.
writexl::write_xlsx(
list(
mensual   = agg_mes %>% mutate(mes = as.character(mes)),
dia_semana = agg_dia %>% mutate(dia_semana = as.character(dia_semana)),
hora      = agg_hora,
dia_hora  = agg_dia_hora %>% mutate(dia_semana = as.character(dia_semana))
),
path = "../output/agg_ts_acciones_2025.xlsx"
)
rm(list = ls())
